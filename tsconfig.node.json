{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@main/*": ["./src/main/*"],
      "@main": ["./src/main"],
      "@preload/*": ["./src/preload/*"],
      "@preload": ["./src/preload"],
      "@shared/*": ["./src/shared/*"],
      "@shared": ["./src/shared"]
    }
  },
  "include": ["src/main", "src/preload", "src/shared", "electron.vite.config.ts"]
}
